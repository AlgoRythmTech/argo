{
  "name": "@argo/api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "tsx watch --import ./src/env-loader.ts src/server.ts",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/server.js",
    "typecheck": "tsc --noEmit",
    "test": "vitest run --passWithNoTests",
    "lint": "echo 'lint: nothing to do'",
    "db:generate": "dotenv -e ../../.env.local -- prisma generate",
    "db:migrate": "dotenv -e ../../.env.local -- prisma migrate dev",
    "db:deploy": "dotenv -e ../../.env.local -- prisma migrate deploy",
    "db:studio": "dotenv -e ../../.env.local -- prisma studio",
    "db:seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
    "@argo/agent": "workspace:*",
    "@argo/build-engine": "workspace:*",
    "@argo/email-automation": "workspace:*",
    "@argo/security": "workspace:*",
    "@argo/shared-types": "workspace:*",
    "@argo/workspace-runtime": "workspace:*",
    "@fastify/cookie": "^9.3.1",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/sensible": "^5.6.0",
    "@fastify/static": "^7.0.4",
    "@prisma/client": "^5.18.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "bullmq": "^5.12.10",
    "dotenv": "^17.4.2",
    "fastify": "^4.28.1",
    "ioredis": "^5.4.1",
    "mongodb": "^6.8.0",
    "nanoid": "^5.0.7",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.2",
    "socket.io": "^4.7.5",
    "stripe": "^17.3.1",
    "undici": "^6.19.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^20.14.10",
    "dotenv-cli": "^11.0.0",
    "prisma": "^5.18.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.4",
    "vitest": "^1.6.0"
  }
}
