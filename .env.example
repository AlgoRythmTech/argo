# ============================================================================
# ARGO — Environment Configuration Template
# ============================================================================
# Copy to `.env.local` (which is gitignored). Never commit real secrets.
# Every variable here is required at boot unless marked OPTIONAL.
# ============================================================================

# ── Runtime ────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
TZ=America/New_York

# ── API ────────────────────────────────────────────────────────────────────
API_HOST=0.0.0.0
API_PORT=4000
API_PUBLIC_URL=http://localhost:4000
API_CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Session signing (generate with: openssl rand -hex 32)
SESSION_SECRET=replace_with_64_hex_chars
COOKIE_SECRET=replace_with_64_hex_chars

# Internal service auth (rotates every 90 days). Used between web ↔ api ↔ workers.
INTERNAL_API_KEY=replace_with_64_hex_chars

# ── Web (Vite) ─────────────────────────────────────────────────────────────
VITE_API_URL=http://localhost:4000
VITE_PUBLIC_APP_URL=http://localhost:5173

# ── Database (MongoDB Community) ───────────────────────────────────────────
# Argo stores customer-generated code, agent invocations, runtime events,
# operation repairs, and templates in MongoDB.
MONGODB_URI=mongodb://argo:argo@localhost:27017/argo?authSource=admin
MONGODB_DB=argo

# ── Postgres (relational: users, ops metadata, billing) ───────────────────
DATABASE_URL=postgresql://argo:argo@localhost:5432/argo?schema=public
DIRECT_URL=postgresql://argo:argo@localhost:5432/argo?schema=public

# ── Redis (BullMQ + cache + websocket adapter) ────────────────────────────
REDIS_URL=redis://localhost:6379

# ── Blaxel — execution provider (production runtime) ──────────────────────
# In dev with no Blaxel access, set BLAXEL_ENABLED=false to use the
# Docker-Compose mock implementation.
BLAXEL_ENABLED=true
BLAXEL_API_KEY=
BLAXEL_API_BASE=https://api.blaxel.ai
BLAXEL_WORKSPACE=algorythm
BLAXEL_DEFAULT_REGION=us-pdx-1
BLAXEL_DEFAULT_IMAGE=blaxel/nextjs:latest
BLAXEL_PUBLIC_HOSTNAME_TEMPLATE=https://{operationId}.argo-ops.run

# ── E2B — build-time test sandbox ─────────────────────────────────────────
E2B_ENABLED=false
E2B_API_KEY=

# ── AgentMail — email plane (production) ──────────────────────────────────
# In dev with no AgentMail access, set AGENTMAIL_ENABLED=false to use Mailpit.
AGENTMAIL_ENABLED=true
AGENTMAIL_API_KEY=
AGENTMAIL_API_BASE=https://api.agentmail.to
AGENTMAIL_FROM_ADDRESS=argoai@agentmail.to
AGENTMAIL_INBOUND_WEBHOOK_SECRET=replace_with_random_64_hex
AGENTMAIL_REPLY_DOMAIN=agentmail.to

# ── Mailpit (dev fallback for AgentMail) ──────────────────────────────────
MAILPIT_SMTP_HOST=localhost
MAILPIT_SMTP_PORT=1025
MAILPIT_UI_URL=http://localhost:8025

# ── LLM providers ─────────────────────────────────────────────────────────
# Primary agent model. Argo's MAPPING/REPAIR/DIGEST states all call this.
# In v1 the default is OpenAI gpt-5.5 (per founder directive).
OPENAI_API_KEY=
# If your OpenAI account doesn't have access to gpt-5.5, OPENAI_MODEL_FALLBACK
# is auto-tried on a 404/400. Update once you confirm the right model string.
OPENAI_MODEL_PRIMARY=gpt-5.5
OPENAI_MODEL_FALLBACK=gpt-4o
OPENAI_API_BASE=https://api.openai.com/v1
OPENAI_REQUEST_TIMEOUT_MS=120000

# Anthropic (BUILDING + repair). claude-opus-4-7 is the v0.1 default; the
# fallback is sonnet-4-5 which all Anthropic accounts have access to.
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL_BUILD=claude-opus-4-7
ANTHROPIC_MODEL_FALLBACK=claude-sonnet-4-5
ANTHROPIC_MODEL_FAST=claude-haiku-4-5-20251001
ANTHROPIC_API_BASE=https://api.anthropic.com

# Emergent universal proxy (alternate route to top Claude models)
EMERGENT_API_KEY=
EMERGENT_API_BASE=https://api.emergent.sh/v1
EMERGENT_ENABLED=false

# ── Auth ──────────────────────────────────────────────────────────────────
# Magic-link only (never passwords). For dev we issue links via Mailpit.
AUTH_MAGIC_LINK_TTL_SECONDS=900
AUTH_SESSION_TTL_DAYS=30
AUTH_ALLOWED_DOMAINS=*

# ── Observability ─────────────────────────────────────────────────────────
SENTRY_DSN=
PROMETHEUS_PORT=9090
OTEL_EXPORTER_OTLP_ENDPOINT=

# ── Trust ratchet — DO NOT lower in v1 ────────────────────────────────────
# Per Section 3, Fatal Flaw #1: first 10 sends per template require approval.
TRUST_RATCHET_MIN_APPROVALS=10
TRUST_RATCHET_APPROVAL_RATE_THRESHOLD=0.95

# ── Repair worker ─────────────────────────────────────────────────────────
REPAIR_POLL_INTERVAL_MS=30000
REPAIR_MAX_CYCLES=3
REPAIR_TRUST_FORCE_SMALL_CHANGE_FIRST=3

# ── Rate limits (Section 12) ──────────────────────────────────────────────
RATE_LIMIT_FORM_PER_MINUTE=60
RATE_LIMIT_WEBHOOK_PER_MINUTE=1000
RATE_LIMIT_API_PER_MINUTE=600

# ── Pricing (Section 14, locked) ──────────────────────────────────────────
PRICING_FIRST_OPERATION_USD=0
PRICING_FIRST_OPERATION_TRIAL_DAYS=30
PRICING_OPERATION_BASE_USD=199
PRICING_OPERATION_SECOND_USD=149
PRICING_OPERATION_THIRD_PLUS_USD=99
